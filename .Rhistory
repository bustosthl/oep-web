quit
library(yaml)
folder_path <- "trabajos_pdf"
files <- list.files(folder_path, pattern = "\\.pdf$")
trabajos <- lapply(files, function(f) {
clean_name <- gsub("\\.pdf$", "", f)
clean_name <- gsub("_", " ", clean_name)
list(
title = clean_name,
author = "OEP",
description = "Trabajo presentado en las Jornadas de Investigación.",
path = paste0(folder_path, "/", f),
categories = list("Jornadas 2026")
)
})
write_yaml(trabajos, "trabajos.yml")
cat("✅ Archivo trabajos.yml generado con éxito.")
